using System.Timers;

System.Timers.Timer timer = new System.Timers.Timer();
bool quit = false;  //бесконечный цикл
int vx; //вектор по икс и игрек
int vy;
int headx;  //голова змеи
int heady;
int[,] GameField;   //игровое поле
int w = 80, h = 40; //ширина и высота поля
int score = 0;  //счёт
int lifes = 3;  //кол-во жизней 
int apples; //кол-во яблок
int level = 0;  //номер уровня

