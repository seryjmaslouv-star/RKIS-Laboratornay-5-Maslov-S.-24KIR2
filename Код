using System.Timers;

System.Timers.Timer timer = new System.Timers.Timer();
bool quit = false;
bool gameOver = false;
int vx;
int vy;
int headx;
int heady;
int[,] GameField;
int w = 50, h = 25; 
int score = 0;
int lifes = 3;
int apples;
int level = 1; 

