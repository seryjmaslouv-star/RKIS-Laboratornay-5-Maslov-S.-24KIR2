void Init() // инициализация
{
    Console.CursorVisible = false;
    Console.SetWindowSize(w + 1, h + 6);
    Console.SetBufferSize(w + 1, h + 6);
}

void Load(int currentLevel) // загрузка уровня
{
    // Полная очистка игрового поля
    GameField = new int[w + 1, h + 1];

    vx = 0;
    vy = 1;
    headx = w / 2;
    heady = h / 2;

    // Инициализация всего поля нулями
    for (int i = 0; i <= w; i++)
    {
        for (int j = 0; j <= h; j++)
        {
            GameField[i, j] = 0;
        }
    }

    GameField[headx, heady] = 1;

    Random random = new Random();
    apples = currentLevel + 1;
    int applesPlaced = 0;

    // Разбрасываем яблоки, избегая положения головы
    while (applesPlaced < apples)
    {
        int x = random.Next(1, w);
        int y = random.Next(1, h);
        if (GameField[x, y] == 0)
        {
            GameField[x, y] = -1;
            applesPlaced++;
        }
    }

    // Создание бордюров
    for (int i = 0; i <= w; i++)
    {
        GameField[i, 0] = 10000;
        GameField[i, h] = 10000;
    }

    for (int i = 0; i <= h; i++)
    {
        GameField[0, i] = 10000;
        GameField[w, i] = 10000;
    }
}

bool Update()
{
    //новая позиция головы
    int newHeadX = headx + vx; 
    int newHeadY = heady + vy;

    // Проверка столкновения со стенами
    if (newHeadX < 1 || newHeadX >= w || newHeadY < 1 || newHeadY >= h)
    {
        return true; // Столкновение со стеной
    }

    // Проверка столкновения с собой
    if (GameField[newHeadX, newHeadY] > 0 && GameField[newHeadX, newHeadY] != 10000)
    {
        return true; // Столкновение с телом
    }

    // Двигаем голову
    headx = newHeadX;
    heady = newHeadY;

    // Проверка на яблоко
    if (GameField[headx, heady] == -1)
    {
        score++;
        apples--;
        GameField[headx, heady] = 1;

        // Увеличиваем тело
        Next(headx - vx, heady - vy, 1, 1);

        if (apples == 0)
        {
            quit = true; // Уровень пройден
            return false;
        }
    }
    else
    {
        // Обычное движение - удаляем хвост и добавляем голову
        Next(headx, heady, 1);
    }

    return false;
}

void Next(int tailX, int tailY, int n, int p = 0) // управление хвостом
{
    if (tailX < 0 || tailX > w || tailY < 0 || tailY > h) return;

    GameField[tailX, tailY] = n + p;

    if (tailX + 1 <= w && GameField[tailX + 1, tailY] == n + p)
        Next(tailX + 1, tailY, n + 1, p);
    else if (tailX - 1 >= 0 && GameField[tailX - 1, tailY] == n + p)
        Next(tailX - 1, tailY, n + 1, p);
    else if (tailY - 1 >= 0 && GameField[tailX, tailY - 1] == n + p)
        Next(tailX, tailY - 1, n + 1, p);
    else if (tailY + 1 <= h && GameField[tailX, tailY + 1] == n + p)
        Next(tailX, tailY + 1, n + 1, p);
    else if (p == 0)
        GameField[tailX, tailY] = 0;
}

void PrintGameField() // отрисовка
{
    for (int y = 0; y <= h; y++)
    {
        for (int x = 0; x <= w; x++)
        {
            Console.SetCursorPosition(x, y + 2);

            if (GameField[x, y] == 0)
                Console.Write(' ');
            else if (GameField[x, y] == -1)
                Console.Write('&');
            else if (GameField[x, y] == 1)
                Console.Write('O');
            else if (GameField[x, y] > 0 && GameField[x, y] < 10000)
                Console.Write('o');
            else if (GameField[x, y] == 10000)
                Console.Write('█');
            else
                Console.Write(' ');
        }
    }
    Console.SetCursorPosition(5, 0);
    Console.Write($"Уровень:{level} Счёт:{score} Жизни:{lifes} Яблок:{apples}    ");
}

void KeyboardUpdate()
{
    if (Console.KeyAvailable)
    {
        ConsoleKey key = Console.ReadKey(true).Key;
        switch (key)
        {
            case ConsoleKey.LeftArrow:
                if (vx != 1)
                {
                    vx = -1;
                    vy = 0;
                }
                break;
            case ConsoleKey.RightArrow:
                if (vx != -1)
                {
                    vx = 1;
                    vy = 0;
                }
                break;
            case ConsoleKey.UpArrow:
                if (vy != 1)
                {
                    vx = 0;
                    vy = -1;
                }
                break;
            case ConsoleKey.DownArrow:
                if (vy != -1)
                {
                    vx = 0;
                    vy = 1;
                }
                break;
            case ConsoleKey.Escape:
                timer.Stop();
                gameOver = true;
                quit = true;
                break;
        }
    }
}

// Основная программа
Init();
SplashScreen();

while (lifes > 0 && !gameOver)
{
    Load(level);
    PrintGameField();
    quit = false;
    bool collision = false;
    bool levelComplete = false;

    while (!quit && !gameOver) // основной цикл
    {
        KeyboardUpdate();

        if (Update()) // Если столкновение
        {
            collision = true;
            quit = true;
        }

        PrintGameField();
        System.Threading.Thread.Sleep(130);
    }

    if (collision) //обработка результата
    {
        lifes--;
        if (lifes > 0)
        {
            // Очищаем экран и показываем сообщение о потере жизни
            Console.SetCursorPosition(w / 2 - 15, h / 2 + 2);
            Console.Write($"Потеряна жизнь! Осталось: {lifes}");
            System.Threading.Thread.Sleep(1500);
            // Очищаем сообщение
            Console.SetCursorPosition(w / 2 - 15, h / 2 + 2);
            Console.Write(new string(' ', 30));

            // Перезагружаем тот же уровень
        }
    }
    else if (apples == 0 && !collision)
    {
        levelComplete = true;
        // Показываем сообщение о переходе на следующий уровень
        Console.SetCursorPosition(w / 2 - 12, h / 2 + 2);
        Console.Write($"Уровень {level} пройден!");
        System.Threading.Thread.Sleep(1000);
        Console.SetCursorPosition(w / 2 - 12, h / 2 + 2);
        Console.Write(new string(' ', 25));

        // Увеличиваем уровень при успешном прохождении
        level++;
    }
}

if (!gameOver)
{
    Console.Clear();
    Console.SetCursorPosition(w / 2 - 10, h / 2 + 2);
    Console.WriteLine("ИГРА ОКОНЧЕНА!");
    Console.SetCursorPosition(w / 2 - 12, h / 2 + 3);
    Console.WriteLine($"Ваш счёт: {score}");
    Console.ReadKey();
}

